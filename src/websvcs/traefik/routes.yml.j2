# /etc/opt/traefik/config/dynamic/routes.yml
# References:
#   - https://www.simplecto.com/use-traefik-with-nginx-apache-caddyserver-serve-static-files/
#   - https://doc.traefik.io/traefik/reference/dynamic-configuration/file/
# yamllint disable rule:document-start rule:document-end
http:
  routers:
    traefik: &service
      rule: Host(`webproxy.{{ site.url }}`)
      entryPoints: websecure
      service: api@internal
      middlewares:
        - authelia@file
        - secure-headers@file
      tls:
        options: intermediate@file
        certResolver: le-http-production
    root:
      <<: *service
      rule: Host(`{{ site.url }}`)
      service: nginx@file
      middlewares:
        - www-redirect@file
    homepage:
      <<: *service
      rule: Host(`dash.{{ site.url }}`)
      service: homepage@file
    isso:
      <<: *service
      rule: Host(`comment.{{ site.url }}`)
      service: isso@file
    guacamole:
      <<: *service
      rule: Host(`remote.{{ site.url }}`)
      service: guacamole@file
      middlewares:
        - authelia@file
        - no-buffering@file
        - secure-headers@file
    archivebox:
      <<: *service
      rule: Host(`archive.{{ site.url }}`)
      service: archivebox@file
    static-files:
      <<: *service
      rule: Host(`www.{{ site.url }}`) || Host(`static.{{ site.url }}`) || Host(`wifi.{{ site.url }}`)
      service: nginx@file
      middlewares:
        - gzip@file
        - secure-headers@file
    # example-static:
    #   <<: *service
    #   rule: (Host(`example.{{ site.url }}`) && PathPrefix(`/static`))
    #   service: nginx@file
    #   middlewares:
    #     - gzip@file
    #     - static-strip-prefix@file
  services:
    homepage:
      loadBalancer:
        servers:
          - url: http://dash.{{ site.url }}:3000/
    isso:
      loadBalancer:
        servers:
          - url: http://comment.{{ site.url }}:8200/
    guacamole:
      loadBalancer:
        servers:
          - url: http://remote.{{ site.url }}:8080/
    archivebox:
      loadBalancer:
        servers:
          - url: http://archive.{{ site.url }}:8000/
    nginx:
      loadBalancer:
        servers:
          - url: http://static.{{ site.url }}:8100/
