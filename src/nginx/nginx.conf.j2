# /etc/opt/nginx/conf/nginx.conf
# Ref:
#   https://nginx.org/en/docs/ngx_core_module.html
#   https://nginx.org/en/docs/http/ngx_http_map_module.html

worker_processes auto;

events {
    worker_connections 1024;
}

error_log stderr error;

http {
    include       mime.types;
    default_type  application/octet-stream;

    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";

    # static, wifi, www
    map $host $subdomain_root {
        ~^(?<subdomain>[a-zA-Z0-9-]+)\.{{ site.url.replace('.', '\.') }}$ /www/$subdomain;
        default /www/static;
    }

    # Block specific file extensions and sensitive directories
    map $uri $blocked_access {
        ~*\.(env|htaccess|htpasswd|conf|config|cfg|yml|yaml|bak|sql|log|ini|json|old|swp|php)$ 1;
        ~*/(.git|.aws|.kube|.docker|wp-admin|wp-content|wp-includes|phpmyadmin|pma|backup|admin|config)(/|$) 1;
        default 0;
    }

    server {
        listen 8100;

        charset    utf-8;
        error_page 404             /error/404.html;
        error_page 500 502 503 504 /error/50x.html;

        server_name *.{{ site.url }};
        root $subdomain_root;

        location /error/ {
            alias /www/error/;
            internal;
        }
        
        if ($blocked_access) {
            return 444;
        }

        location ~ \.(mp3|mp4) {
            sendfile           on;
            sendfile_max_chunk 1m;
            tcp_nodelay        on;
            keepalive_timeout  65;
            expires 30d;
        }

        location / {
            try_files $uri $uri/ =404;
            index index.html index.htm;
            expires 7d;
        }
    }
}
