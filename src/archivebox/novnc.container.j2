# /etc/containers/systemd/novnc.container
# Ref: https://docs.podman.io/en/latest/markdown/podman-systemd.unit.5.html
# It doesn't have any authentication or encryption, so only run intermittently.

[Unit]
Description="Homelab: VNC remote deskop for ArchiveBox, not secure"
StartLimitIntervalSec=30
StartLimitBurst=10
Wants=network.target
After=network-online.target

[Container]
Image=localhost/novnc:latest
ContainerName=novnc
AutoUpdate=registry
NoNewPrivileges=true

Network=net.network
HostName=vnc.{{ site.url }}
IP={{ websvcs.container_subnet }}.18
# port 5900

Environment=TZ={{ personal.timezone }}
# Ref:
# https://github.com/ArchiveBox/ArchiveBox/wiki/Chromium-Install#setting-up-a-chromium-user-profile
# https://github.com/ArchiveBox/ArchiveBox/wiki/Chromium-Install#docker-vnc-setup
Environment=DISPLAY_WIDTH=1920
Environment=DISPLAY_HEIGHT=1080
Environment=RUN_XTERM=no
Environment=RUN_FLUXBOX=yes
Environment=RUN_NOVNC=no
Environment=NOVNC_PORT=8300

[Service]
Restart=on-failure
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
