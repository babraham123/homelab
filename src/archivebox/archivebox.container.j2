# /etc/containers/systemd/archivebox.container
# Ref: https://docs.podman.io/en/latest/markdown/podman-systemd.unit.5.html

[Unit]
Description="Homelab: Archive websites and web content"
StartLimitIntervalSec=30
StartLimitBurst=10
Wants=network.target
After=network-online.target

[Container]
Image=docker.io/archivebox/archivebox:latest
ContainerName=archivebox
AutoUpdate=registry
NoNewPrivileges=true

Network=net.network
HostName=archive.{{ site.url }}
IP={{ websvcs.container_subnet }}.17
# port 8000

Environment=TZ={{ personal.timezone }}
# Ref:
# https://github.com/ArchiveBox/ArchiveBox/wiki/Docker#configuration
# https://github.com/ArchiveBox/ArchiveBox/wiki/Configuration
Environment=BIND_ADDR=0.0.0.0:8000
Environment=LISTEN_HOST=archive.{{ site.url }}:443
Environment=ALLOWED_HOSTS=archive.{{ site.url }}
Environment=CSRF_TRUSTED_ORIGINS=https://archive.{{ site.url }}
Environment=IN_DOCKER=true
Environment=PUBLIC_INDEX=False
Environment=PUBLIC_SNAPSHOTS=False
Environment=PUBLIC_ADD_VIEW=False
Environment=PUID=911
Environment=PGID=911
Environment=CHECK_SSL_VALIDITY=True
Environment=CHROME_USER_DATA_DIR=/data/personas/Default/chrome_profile
Environment=DISPLAY=novnc:0.0
Environment=REVERSE_PROXY_USER_HEADER=Remote-User
Environment=REVERSE_PROXY_WHITELIST={{ websvcs.container_subnet }}.6
Environment=LOGOUT_REDIRECT_URL=https://dash.{{ site.url }}

Secret=guacamole_pg_password,type=env,target=POSTGRES_PASSWORD

# TODO: install hard drives and use mounted dir
Volume=/var/opt/archivebox:/data
Volume=chromium.volume:/data/personas/Default

[Service]
Restart=on-failure
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
