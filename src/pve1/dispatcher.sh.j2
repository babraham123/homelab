#!/usr/bin/env bash
# SSH Forced Command Dispatcher
# This script is triggered by the SSH daemon when the specific automation key is used.
# It parses $SSH_ORIGINAL_COMMAND to determine which action to take.
# Usage:
#   ssh autoadmin@pve1 CMD

set -euo pipefail

log_action() {
  local level="$1"
  local message="$2"
  # Log to system journal (view with: journalctl -t dispatcher)
  /usr/bin/logger -t "dispatcher" -p "user.${level}" "$message"
}

# Log the incoming request
log_action "info" "Request received: '${SSH_ORIGINAL_COMMAND}' from ${SSH_CLIENT}"

case "$SSH_ORIGINAL_COMMAND" in

  "status_check")
    echo ">> System Status:"
    /usr/bin/uptime
    /usr/bin/ping -c1 google.com
    sudo /usr/bin/systemctl status pve-manager
    log_action "info" "Status check performed."
    ;;

  *)
    log_action "warning" "DENIED: Unauthorized command attempt: '${SSH_ORIGINAL_COMMAND}'"
    echo "Error: Command not recognized or not allowed."
    exit 1
    ;;
esac
exit 0
