# /etc/systemd/system/geoip_generator.service

[Unit]
Description="Homelab: Generate IP to country maps for HAProxy"
StartLimitIntervalSec=30
StartLimitBurst=10
Wants=network.target
After=network-online.target

[Service]
Type=simple

Environment=TZ={{ personal.timezone }}

ExecStart=/usr/local/bin/geoip_generator.py

Restart=on-failure
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
